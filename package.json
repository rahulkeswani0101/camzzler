{
  "name": "camzzler",
  "version": "1.0.7",
  "description": "Lightweight camera abstraction for browsers and mobile WebViews",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "camera",
    "webrtc",
    "selfie",
    "webview",
    "mobile",
    "photo",
    "capture",
    "react",
    "vue",
    "angular",
    "ios",
    "android",
    "webcam",
    "video",
    "getUserMedia",
    "native",
    "ui"
  ],
  "author": "Rahul Keswani <rahulkeswani010@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rahulkeswani0101/camzzler"
  },
  "bugs": {
    "url": "https://github.com/rahulkeswani0101/camzzler/issues"
  },
  "homepage": "https://github.com/rahulkeswani0101/camzzler#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "sideEffects": false
}

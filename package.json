{
  "name": "camzzler",
  "version": "1.0.0",
  "description": "Lightweight camera abstraction for browsers and mobile WebViews",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    "0": [
      {
        "import": "./dist/index.mjs",
        "require": "./dist/index.js",
        "types": "./dist/index.d.ts"
      }
    ],
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --minify",
    "dev": "tsup src/index.ts --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "camera",
    "webrtc",
    "selfie",
    "webview",
    "mobile"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "sideEffects": "false"
}
